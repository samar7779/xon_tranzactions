# ───── PostgreSQL DB ulanish ─────
DATABASE_URL="postgresql://xontranz:STRONG_PASS@localhost:5432/xon_tranzactions?schema=public"

# ───── App ─────
PORT=3001
NODE_ENV=development

# ───── JWT (admin auth) ─────
# openssl rand -hex 64
JWT_SECRET="CHANGE_ME_TO_LONG_RANDOM_HEX_STRING"
JWT_EXPIRES_IN="12h"

# ───── Credential password shifrlash ─────
# AES-256-GCM uchun 32 byte kalit (base64). openssl rand -base64 32
CRED_ENC_KEY="CHANGE_ME_32_BYTES_BASE64_KEY________________="

# ───── KapitalBank API (production) ─────
# Hujjat: tz/KapitalAPI V3.pdf
KAPITALBANK_API_URL="https://m.bank24.uz:2713/Mobile.svc"
KAPITALBANK_TIMEOUT_MS=15000

# ───── Cron — bankdan ma'lumot olish ─────
TXN_SYNC_CRON="*/5 * * * *"   # har 5 daqiqa
TXN_SYNC_DAYS_BACK=1           # nechta kun orqaga olib turamiz

# ───── CORS (frontend manzili) ─────
CORS_ORIGIN="http://localhost:3000"

# ───── Swagger ─────
SWAGGER_PATH="docs"

# ───── Default admin (seed) ─────
SEED_ADMIN_EMAIL="admin@xon.local"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_NAME="Bosh Admin"
