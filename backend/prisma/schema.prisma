generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ROLE — RBAC: rol va unga biriktirilgan ruxsatlar (permissions)
// Permissions list constants: backend/src/auth/permissions.ts
// ─────────────────────────────────────────────────────────────────
model Role {
  id          String      @id @default(cuid())
  name        String      @unique @db.VarChar(64)         // SUPERADMIN, ACCOUNTANT
  label       String      @db.VarChar(128)                 // "Bosh admin"
  description String?     @db.Text
  permissions String[]                                     // ["transactions:view", "banks:manage", ...]
  isSystem    Boolean     @default(false) @map("is_system") // o'chirib bo'lmaydigan tizim roli

  users       AdminUser[]

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("roles")
}

// ─────────────────────────────────────────────────────────────────
// ADMIN USER — admin paneliga kirish uchun
// ─────────────────────────────────────────────────────────────────
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(190)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String?   @map("full_name") @db.VarChar(190)
  role         AdminRole @default(ADMIN)                   // legacy enum (eski guard'lar uchun)
  roleId       String?   @map("role_id")                   // Yangi RBAC: Role tablega FK
  roleRef      Role?     @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([roleId])
  @@map("admin_users")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  VIEWER
}

// ─────────────────────────────────────────────────────────────────
// TRANSACTION — asosiy to'lov yozuvi
// ─────────────────────────────────────────────────────────────────
model Transaction {
  id            String    @id @default(cuid())
  externalId    String?   @unique @map("external_id")   // Bank tomonidan berilgan global_id yoki b2_id
  type          TxnType
  status        TxnStatus @default(PENDING)
  direction     TxnDirection                            // IN yoki OUT

  // Pul ma'lumotlari
  amount        Decimal   @db.Decimal(18, 2)
  currency      String    @default("UZS") @db.VarChar(3)

  // Manba/qabul qiluvchi
  fromMfo       String?   @map("from_mfo") @db.VarChar(8)
  fromAccount   String?   @map("from_account")
  fromName      String?   @map("from_name")
  fromInn       String?   @map("from_inn") @db.VarChar(16)
  toMfo         String?   @map("to_mfo") @db.VarChar(8)
  toAccount     String?   @map("to_account")
  toName        String?   @map("to_name")
  toInn         String?   @map("to_inn") @db.VarChar(16)

  // Tafsilot
  description   String?   @db.Text
  reference     String?   @db.VarChar(64)   // uniq — bank ref/code
  purposeCode   String?   @map("purpose_code") @db.VarChar(16)
  docNumber     String?   @map("doc_number") @db.VarChar(64)
  docType       String?   @map("doc_type") @db.VarChar(8)

  // Bank ID'lari — composite externalId'ni hosil qilish uchun ham, alohida indeks uchun ham
  bankGeneralId String?   @map("bank_general_id") @db.VarChar(64)  // general_id (NCI)
  bankB2Id      String?   @map("bank_b2_id") @db.VarChar(64)        // b2_id

  // Bank ichki ma'lumotlari
  bankClientId  String?   @map("bank_client_id") @db.VarChar(32)    // client_id
  bankBranch    String?   @map("bank_branch") @db.VarChar(8)        // branch (operatsiya o'tgan filial)

  // Qo'shimcha vaqtlar
  valueDate     DateTime? @map("value_date") @db.Date               // vdate — mablag' mavjud bo'lish sanasi
  operationTime String?   @map("operation_time") @db.VarChar(8)     // time HH:mm:ss
  settlementTime String?  @map("settlement_time") @db.VarChar(8)    // stime
  inputAt       DateTime? @map("input_at")                          // input_date + input_time birlashtirilgan

  // Anor 24/7 va xato
  isAnor        Boolean   @default(false) @map("is_anor")           // anor=1
  bankErrCode   String?   @map("bank_err_code") @db.VarChar(32)     // err
  bankErrMsg    String?   @map("bank_err_msg") @db.Text             // err_msg

  // To'liq raw javob va kelajakda qo'shilishi mumkin bo'lgan fieldlar uchun
  metadata      Json?                                                // bank javobining to'liq raw
  rawExtra      Json?     @map("raw_extra")                          // bizga noma'lum fieldlar (future-proof)

  // ─── MANBA (Sync / Import) ───
  // SYNC = bank API'dan avtomatik olingan, IMPORT = qo'lda Excel'dan kiritilgan
  source        TxnSource @default(SYNC)
  // Qo'lda import qilinganda — bizning kategoriya ro'yxatida yo'q nomlar matn sifatida saqlanadi
  // TEXT (unlimited) — Excel'dan har xil uzunlikdagi nomlar kelishi mumkin
  importCategoryText     String?  @map("import_category_text") @db.Text
  // Qo'lda import qilinganda — kontragent nomi (free-text, Counterparty bilan match qilinmagan)
  importCounterpartyText String?  @map("import_counterparty_text") @db.Text
  // Qo'lda import qilinganda — bank nomi (Excel'dagi original matn, agar bank topilmagan bo'lsa)
  importBankNameText     String?  @map("import_bank_name_text") @db.Text
  // Qo'lda import qilinganda — kim import qilgan va qachon
  importedBy             String?  @map("imported_by") @db.VarChar(190)
  importedAt             DateTime? @map("imported_at")
  // Import batch (tarix + ko'plab tranzaksiyalarni bitta yozuv bilan o'chirish/eksport qilish)
  importBatchId          String?   @map("import_batch_id")
  importBatch            ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  // Bog'lanishlar
  bankId        String?      @map("bank_id")
  bank          Bank?        @relation(fields: [bankId], references: [id])
  accountId     String?      @map("account_id")
  account       BankAccount? @relation(fields: [accountId], references: [id])

  // Kategoriya — 2 darajali (F va G ustunlar Sheets'dagi). Bor bo'lsa, qayta yozilmaydi.
  categoryId    String?      @map("category_id")
  category      Category?    @relation("TxnCategory", fields: [categoryId], references: [id])
  subcategoryId String?      @map("subcategory_id")
  subcategory   Category?    @relation("TxnSubcategory", fields: [subcategoryId], references: [id])
  // Topilgan shartnoma raqami (description'dan ajratilgan + CRM bilan tasdiqlangan)
  // VarChar(128) — import paytida uzunroq shartnoma raqamlari kelishi mumkin
  contractNumber String?     @map("contract_number") @db.VarChar(128)
  // Shartnoma qo'lda kiritilganmi (CRM tekshirilmagan, foydalanuvchi javobgar)
  // true bo'lsa — frontend "QO'LDA" badge ko'rsatadi (XATO emas)
  isContractManual Boolean   @default(false) @map("is_contract_manual")
  // Kategoriya qachon va kim tomonidan qo'yilgan (auto/manual/cron/import)
  categorizedAt   DateTime?  @map("categorized_at")
  categorizedBy   String?    @map("categorized_by") @db.VarChar(20)
  categorizedById String?    @map("categorized_by_id")

  // Billing: avto-match orqali mijozga bog'lanadi (INN orqali)
  customerId    String?     @map("customer_id")
  customer      Customer?   @relation(fields: [customerId], references: [id])
  matchStatus   MatchStatus @default(UNMATCHED) @map("match_status")
  matchedAt     DateTime?   @map("matched_at")

  // Qo'lda tanlangan kontragent (Counterparty jadvali bo'yicha) — INN avto-lookup ustidan
  // Foydalanuvchi tahrirlash dialogida qidirib tanlaganda
  manualCounterpartyId String?    @map("manual_counterparty_id")
  manualCounterparty   Counterparty? @relation("ManualCounterparty", fields: [manualCounterpartyId], references: [id])

  // Biriktirilgan fayllar (ariza, hujjat va h.k.)
  attachments   TransactionAttachment[]
  xonpayMatches XonpayTransaction[]

  // To'lov bosqichlariga taqsimlanishi (bitta tranzaksiya = bir nechta payment)
  payments      Payment[]

  // Vaqtlar
  txnDate       DateTime  @map("txn_date")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([txnDate])
  // Kompozit indeks list orderBy [txnDate desc, id desc] uchun.
  // Postgres'ga index scan + range filter + LIMIT'ni tez bajarishga imkon beradi.
  @@index([txnDate(sort: Desc), id(sort: Desc)])
  @@index([status])
  @@index([type, direction])
  @@index([bankId])
  @@index([accountId])
  @@index([customerId])
  @@index([matchStatus])
  @@index([fromInn])
  @@index([bankB2Id])
  @@index([bankGeneralId])
  @@index([valueDate])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([contractNumber])
  @@index([source])
  @@index([importBatchId])
  @@index([manualCounterpartyId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────
// TRANSACTION ATTACHMENT — tranzaksiyaga biriktirilgan fayllar
// (ariza, hujjat, rasm). To'lov ariz orqali to'g'rilash uchun.
// ─────────────────────────────────────────────────────────────────
model TransactionAttachment {
  id            String      @id @default(cuid())
  txId          String      @map("tx_id")
  transaction   Transaction @relation(fields: [txId], references: [id], onDelete: Cascade)

  type          String      @db.VarChar(32)              // 'ariza' | 'document' | 'image' (kelajakda)
  filename      String      @db.VarChar(255)              // foydalanuvchi ko'rgan nom
  mimeType      String      @map("mime_type") @db.VarChar(128)
  fileSize      Int         @map("file_size")             // bayt
  storagePath   String      @map("storage_path") @db.VarChar(500)  // server diskdagi yo'l

  contractNumber String?    @map("contract_number") @db.VarChar(128)  // qaysi shartnomaga tegishli
  notes         String?     @db.Text                       // izoh

  uploadedBy    String?     @map("uploaded_by") @db.VarChar(190)     // email
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")

  @@index([txId])
  @@index([uploadedAt])
  @@map("transaction_attachments")
}

// ─────────────────────────────────────────────────────────────────
// IMPORT BATCH — har bir Excel import sessiyasi alohida yozuv
// Tarix, yuklab olish (re-export), o'chirish uchun
// ─────────────────────────────────────────────────────────────────
model ImportBatch {
  id           String        @id @default(cuid())
  kind         String        @db.VarChar(32)              // 'transactions' | 'counterparties' (kelajakda)
  fileName     String?       @map("file_name") @db.VarChar(255)
  fileSize     Int?          @map("file_size")             // bayt
  importedBy   String?       @map("imported_by") @db.VarChar(190)
  importedAt   DateTime      @default(now()) @map("imported_at")
  rowsTotal    Int           @default(0) @map("rows_total")
  rowsAdded    Int           @default(0) @map("rows_added")
  rowsSkipped  Int           @default(0) @map("rows_skipped")
  rowsErrors   Int           @default(0) @map("rows_errors")
  notes        String?       @db.Text                       // 'Legacy import' kabi izoh

  transactions Transaction[]

  @@index([importedAt])
  @@index([kind])
  @@map("import_batches")
}

enum MatchStatus {
  UNMATCHED     // INN topilmadi yoki hali tekshirilmagan
  AUTO          // Avtomatik mos topildi (INN orqali)
  MANUAL        // Admin qo'lda biriktirgan
  PARTIAL       // Qisman taqsimlangan
  IGNORED       // Admin "bu billing'ga aloqasi yo'q" deb belgilagan
}

enum TxnType {
  TRANSFER       // O'tkazma
  PAYMENT        // To'lov
  SALARY         // Maosh
  TAX            // Soliq
  FEE            // Komissiya
  REFUND         // Qaytarish
  OTHER          // Boshqa
}

enum TxnStatus {
  PENDING        // Kutilmoqda
  COMPLETED      // Yakunlangan
  FAILED         // Muvaffaqiyatsiz
  CANCELLED      // Bekor qilingan
  REVERSED       // Qaytarilgan
}

enum TxnDirection {
  IN             // Kiruvchi
  OUT            // Chiquvchi
}

enum TxnSource {
  SYNC           // Bank API'dan avtomatik sync
  IMPORT         // Qo'lda Excel'dan import qilingan (standart format)
  MANUAL         // Qo'lda admin tomonidan kiritilgan (kelajakda)
  ALOQA_BANK     // Aloqa Bank Excel import (read-only — edit/delete/category bloklangan)
}

// ─────────────────────────────────────────────────────────────────
// BANK — bank manbalari (Kapitalbank, Uzcard, Humo, ...)
// ─────────────────────────────────────────────────────────────────
model Bank {
  id           String           @id @default(cuid())
  code         String           @unique @db.VarChar(32)  // KAPITALBANK, UZCARD, HUMO
  name         String           @db.VarChar(128)
  apiBaseUrl   String?          @map("api_base_url")
  apiKind      BankApiKind      @default(KAPITALBANK_V3) @map("api_kind")
  isActive     Boolean          @default(true) @map("is_active")
  syncIntervalMinutes Int       @default(5) @map("sync_interval_minutes") // har necha daqiqada sync

  credentials  BankCredential[]
  accounts     BankAccount[]
  transactions Transaction[]

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("banks")
}

enum BankApiKind {
  KAPITALBANK_V3
  IPAK_YOLI_V1   // Ipak Yo'li — Kapitalbank bilan bir xil OpenAPI 24/7 framework (mb.ipakyulibank.uz)
  GENERIC
}

// ─────────────────────────────────────────────────────────────────
// BANK CREDENTIAL — har bir bankka ulanish (login/parol + org)
// admin panel orqali kiritiladi, parol shifrlanib saqlanadi
// ─────────────────────────────────────────────────────────────────
model BankCredential {
  id              String        @id @default(cuid())
  bankId          String        @map("bank_id")
  bank            Bank          @relation(fields: [bankId], references: [id], onDelete: Cascade)

  label           String        @db.VarChar(128)              // "Xon Saroy — Kapitalbank Yunusobod"
  loginPrefix     String?       @map("login_prefix") @db.VarChar(8)  // "IB#" yoki bo'sh
  loginName       String        @map("login_name") @db.VarChar(128)
  passwordEnc     String        @map("password_enc") @db.Text       // AES-256-GCM bilan shifrlangan
  clientIdExt     String?       @map("client_id_ext") @db.VarChar(64) // KapitalBank Client.id (APILogin javobida)
  branch          String?       @db.VarChar(8)                       // MFO
  authMode        BankAuthMode  @default(IP_WHITELIST) @map("auth_mode")
  isActive        Boolean       @default(true) @map("is_active")
  useProxy        Boolean       @default(false) @map("use_proxy")  // ahost orqali yuborish (IP whitelist'ni chetlab o'tish)

  // sessiya holatini ham saqlab qo'yamiz (SMS rejim uchun zaxira)
  sid             String?       @db.VarChar(255)
  sidExpiresAt    DateTime?     @map("sid_expires_at")
  lastVerifiedAt  DateTime?     @map("last_verified_at")
  lastError       String?       @map("last_error") @db.Text

  accounts        BankAccount[]

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([bankId, loginName])
  @@map("bank_credentials")
}

enum BankAuthMode {
  IP_WHITELIST    // Server IP banked oq ro'yxatda — har so'rovda Basic Auth
  SMS_SID         // APILogin orqali SID olib, kesh
}

// ─────────────────────────────────────────────────────────────────
// BANK ACCOUNT — kompaniya hisob raqamlari (har biri o'z credential'iga bog'lanadi)
// ─────────────────────────────────────────────────────────────────
model BankAccount {
  id             String          @id @default(cuid())
  bankId         String          @map("bank_id")
  bank           Bank            @relation(fields: [bankId], references: [id])
  credentialId   String          @map("credential_id")
  credential     BankCredential  @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  branch         String          @db.VarChar(8)              // MFO (5 belgi, 8 zaxira)
  accountNo      String          @map("account_no") @db.VarChar(32)
  ownerName      String?         @map("owner_name") @db.VarChar(128)
  currency       String          @default("UZS") @db.VarChar(3)
  balance        Decimal?        @db.Decimal(18, 2)
  syncEnabled    Boolean         @default(true) @map("sync_enabled")
  lastSyncedAt   DateTime?       @map("last_synced_at")

  transactions   Transaction[]

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([branch, accountNo])
  @@index([credentialId])
  @@map("bank_accounts")
}

// ─────────────────────────────────────────────────────────────────
// CATEGORY — tranzaksiya turlari (xarajat/daromad kategoriyalari)
// ─────────────────────────────────────────────────────────────────
model Category {
  id           String        @id @default(cuid())
  code         String        @unique @db.VarChar(64)
  name         String        @db.VarChar(128)
  parentId     String?       @map("parent_id")
  parent       Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryHierarchy")
  color        String?       @db.VarChar(16)   // UI uchun hex rang
  icon         String?       @db.VarChar(64)
  isSystem     Boolean       @default(false) @map("is_system")  // seed kategoriyalar — o'chirilmaydi
  sortOrder    Int           @default(0) @map("sort_order")

  transactions   Transaction[] @relation("TxnCategory")
  subTransactions Transaction[] @relation("TxnSubcategory")

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────
// TRANSACTION CATEGORY HISTORY — tranzaksiya kategoriyasi audit logi
// Kim, qachon, qaysi kategoriyani qo'ydi/o'zgartirdi — to'liq tarix.
// ─────────────────────────────────────────────────────────────────
model TransactionCategoryHistory {
  id               String   @id @default(cuid())
  txId             String   @map("tx_id")
  action           String   @db.VarChar(20)            // 'sync' | 'auto' | 'manual' | 'cron' | 'force'
  actorId          String?  @map("actor_id")            // user id (manual uchun)
  actorName        String?  @map("actor_name") @db.VarChar(128)  // email / 'cron' / 'sync'
  oldCategoryId    String?  @map("old_category_id")
  oldCategoryName  String?  @map("old_category_name") @db.VarChar(128)
  oldSubcategoryId String?  @map("old_subcategory_id")
  oldSubcategoryName String? @map("old_subcategory_name") @db.VarChar(128)
  newCategoryId    String?  @map("new_category_id")
  newCategoryName  String?  @map("new_category_name") @db.VarChar(128)
  newSubcategoryId String?  @map("new_subcategory_id")
  newSubcategoryName String? @map("new_subcategory_name") @db.VarChar(128)
  contractNumber   String?  @map("contract_number") @db.VarChar(32)
  reason           String?  @db.Text                    // 'CRM topdi: ...' / 'qo'lda o'zgartirildi'
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([txId, createdAt])
  @@index([actorId])
  @@map("transaction_category_history")
}

// ─────────────────────────────────────────────────────────────────
// CRM CONTRACT CACHE — XonSaroy CRM'dan olingan shartnomalar keshi
// Har tranzaksiyada CRM'ga so'rov yubormaslik uchun.
// ─────────────────────────────────────────────────────────────────
model CrmContract {
  contractNumber  String   @id @map("contract_number") @db.VarChar(128)  // Transaction bilan teng
  customerName    String?  @map("customer_name") @db.Text                  // uzun org nomlari uchun
  status          String?  @db.VarChar(128)
  objectName      String?  @map("object_name") @db.VarChar(255)
  apartmentNumber String?  @map("apartment_number") @db.VarChar(64)
  phone           String?  @db.VarChar(64)
  rawSnapshot     Json?    @map("raw_snapshot")          // CRM javobining qisqartmasi
  found           Boolean  @default(true)                // false → CRM'da topilmadi, kelajakda yana urinma
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastVerifiedAt  DateTime @default(now()) @map("last_verified_at")
  lastError       String?  @map("last_error") @db.Text

  @@index([lastVerifiedAt])
  @@index([status])
  @@map("crm_contracts")
}

// ─────────────────────────────────────────────────────────────────
// XONPAY SYNC LOG — har bir sync (manual + cron) tarixi
// ─────────────────────────────────────────────────────────────────
model XonpaySyncLog {
  id          String    @id @default(cuid())
  trigger     String    @db.VarChar(16)  // 'manual' | 'cron'
  actorId     String?   @map("actor_id")
  actorEmail  String?   @map("actor_email") @db.VarChar(190)
  actorName   String?   @map("actor_name") @db.VarChar(190)  // To'liq ism (User.fullName)
  status      String    @db.VarChar(16)  // 'running' | 'success' | 'failed' | 'cancelled'
  pages       Int       @default(0)
  fetched     Int       @default(0)
  xonpay      Int       @default(0)
  inserted    Int       @default(0)
  updated     Int       @default(0)
  matched     Int       @default(0)
  errors      Int       @default(0)
  errorMessage String?  @map("error_message") @db.Text
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  durationMs  Int?      @map("duration_ms")

  @@index([startedAt])
  @@index([trigger, startedAt])
  @@map("xonpay_sync_logs")
}

// ─────────────────────────────────────────────────────────────────
// XONPAY TRANSACTIONS — Biling moduli
// XonSaroy CRM dan faqat payment_method='Xon Pay' to'lovlar.
// Reconcile: purpose ichidagi UUID (XONPAY:(...)) orqali bank Transaction
// description'dagi UUID bilan moslashtirilib, matchedTxId ga link qo'yiladi.
// Maqsad: qancha XonPay'dan keldi vs qancha Kapitalbankka tushdi.
// ─────────────────────────────────────────────────────────────────
model XonpayTransaction {
  externalId           String   @id @map("external_id") @db.VarChar(255)  // CRM external_id
  xonpayUuid           String?  @map("xonpay_uuid") @db.VarChar(64)       // purpose'dan extract: XONPAY:(UUID)
  crmId                BigInt?  @map("crm_id")
  crmUuid              String?  @map("crm_uuid") @db.VarChar(64)
  orderId              BigInt?  @map("order_id")
  contract             String?  @db.VarChar(128)
  amount               BigInt   @default(0)
  datePaid             DateTime? @map("date_paid") @db.Date
  type                 String?  @db.VarChar(128)
  category             String?  @db.VarChar(128)
  status               String?  @db.VarChar(64)
  purpose              String?  @db.Text
  fullName             String?  @map("full_name") @db.Text
  objectName           String?  @map("object_name") @db.VarChar(255)
  isProblematic        Boolean  @default(false) @map("is_problematic")
  isReceivedFromBank   Boolean  @default(false) @map("is_received_from_bank")
  crmCreatedAt         DateTime? @map("crm_created_at")
  crmUpdatedAt         DateTime? @map("crm_updated_at")

  // ── Reconciliation ──
  matchedTxId          String?  @map("matched_tx_id")
  matchedTx            Transaction? @relation(fields: [matchedTxId], references: [id], onDelete: SetNull)
  matchedExternalId    String?  @map("matched_external_id") @db.VarChar(255)
  matchedAmount        BigInt?  @map("matched_amount")
  matchedDate          DateTime? @map("matched_date") @db.Date
  isMatched            Boolean  @default(false) @map("is_matched")
  matchedAt            DateTime? @map("matched_at")
  lastCheckedAt        DateTime? @map("last_checked_at")

  syncedAt             DateTime @default(now()) @map("synced_at")
  updatedAt            DateTime @updatedAt @map("updated_at_local")

  @@index([contract])
  @@index([datePaid])
  @@index([xonpayUuid])
  @@index([isMatched, datePaid])
  @@index([matchedTxId])
  @@map("xonpay_transactions")
}

// ─────────────────────────────────────────────────────────────────
// SYNC LOG — bank API'dan ma'lumot olish tarixi
// ─────────────────────────────────────────────────────────────────
model SyncLog {
  id           String      @id @default(cuid())
  source       String      @db.VarChar(255)             // "accountNo · ownerName" yoki bank kodi
  accountId    String?     @map("account_id")
  status       SyncStatus
  fetched      Int         @default(0)
  saved        Int         @default(0)
  errors       Int         @default(0)
  errorMessage String?     @map("error_message") @db.Text
  durationMs   Int?        @map("duration_ms")
  startedAt    DateTime    @default(now()) @map("started_at")
  finishedAt   DateTime?   @map("finished_at")

  @@index([startedAt])
  @@index([source, status])
  @@index([accountId])
  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ─────────────────────────────────────────────────────────────────
// TRANSACTION CHANGE LOG — bank tomonida o'chirilgan yoki o'zgartirilgan
// tranzaksiyalar tarixi. Sync re-verify chog'ida farq aniqlansa, mavjud
// yozuv update/delete qilinadi va shu yerga audit yoziladi.
// ─────────────────────────────────────────────────────────────────
model TransactionChangeLog {
  id              String          @id @default(cuid())
  // Eski tx ID (delete bo'lsa null bo'ladi — tx o'chirilgan)
  txId            String?         @map("tx_id")
  // Asl externalId (composite) — qidirish uchun
  externalId      String          @map("external_id") @db.VarChar(255)
  accountId       String?         @map("account_id")
  changeType      TxChangeType    @map("change_type")
  // O'zgargan field'lar nomlari (masalan ['status','amount'])
  fieldsChanged   String[]        @map("fields_changed") @default([])
  // Eski qiymatlar (delete uchun butun qator snapshot)
  oldData         Json?           @map("old_data")
  // Yangi qiymatlar (delete uchun null)
  newData         Json?           @map("new_data")
  // Qulay qidirish uchun snapshot fields (delete bo'lsa eski qiymat, edit uchun yangi)
  txnDate         DateTime?       @map("txn_date")
  amount          Decimal?        @db.Decimal(18, 2)
  direction       TxnDirection?
  contractNumber  String?         @map("contract_number") @db.VarChar(128)
  bankNameSnap    String?         @map("bank_name_snap") @db.VarChar(120)
  accountNoSnap   String?         @map("account_no_snap") @db.VarChar(64)
  // Audit
  detectedAt      DateTime        @default(now()) @map("detected_at")
  detectedBy      String?         @map("detected_by") @db.VarChar(190)  // 'sync' | 'manual:<email>'
  note            String?         @db.Text

  @@index([detectedAt(sort: Desc)])
  @@index([changeType])
  @@index([accountId, detectedAt])
  @@index([externalId])
  @@map("transaction_change_logs")
}

enum TxChangeType {
  DELETED   // bank tomonida o'chirilgan (yoki bekor qilingan)
  EDITED    // bank field o'zgartirgan (status, amount, va h.k.)
}

// ─────────────────────────────────────────────────────────────────
// SETTING — umumiy key/value sozlamalar (kelajakda kengayadi)
// Hozir: syncMinDate — sync bu sanadan oldingi tranzaksiyalarni
// olmaydi (import qilingan tarixiy ma'lumotlarni himoya qilish uchun)
// ─────────────────────────────────────────────────────────────────
model Setting {
  key       String   @id @db.VarChar(64)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(190)

  @@map("settings")
}

// ═════════════════════════════════════════════════════════════════
// BILLING — mijozlar, shartnomalar, bosqichlar, to'lovlar
// ═════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────
// CUSTOMER — buyurtmachi (yuridik shaxs)
// Bank tranzaksiyasi INN orqali avtomatik mos topiladi
// ─────────────────────────────────────────────────────────────────
model Customer {
  id            String     @id @default(cuid())
  name          String     @db.VarChar(255)               // "OOO Tashkent Mall"
  inn           String?    @unique @db.VarChar(16)        // 300123456 — INN/STIR
  pinfl         String?    @db.VarChar(16)                // jismoniy shaxs uchun
  shortName     String?    @map("short_name") @db.VarChar(64)
  contactPerson String?    @map("contact_person") @db.VarChar(128)
  phone         String?    @db.VarChar(32)
  email         String?    @db.VarChar(128)
  address       String?    @db.Text
  bankAccount   String?    @map("bank_account") @db.VarChar(32)
  bankMfo       String?    @map("bank_mfo") @db.VarChar(8)
  notes         String?    @db.Text
  isActive      Boolean    @default(true) @map("is_active")

  contracts     Contract[]
  transactions  Transaction[]

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([name])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────
// CONTRACT — shartnoma (mijoz bilan)
// ─────────────────────────────────────────────────────────────────
model Contract {
  id            String           @id @default(cuid())
  number        String           @unique @db.VarChar(64)  // SHRT-2026-001 — avto-generatsiya
  customerId    String           @map("customer_id")
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)

  title         String           @db.VarChar(255)         // "Tashkent Mall qurilishi"
  description   String?          @db.Text
  projectAddress String?         @map("project_address") @db.Text

  totalAmount   Decimal          @map("total_amount") @db.Decimal(18, 2)
  currency      String           @default("UZS") @db.VarChar(3)

  signDate      DateTime         @map("sign_date")
  startDate     DateTime?        @map("start_date")
  endDate       DateTime?        @map("end_date")

  status        ContractStatus   @default(ACTIVE)
  notes         String?          @db.Text

  stages        ContractStage[]
  payments      Payment[]

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([status])
  @@index([signDate])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT          // Loyiha
  ACTIVE         // Faol — to'lov kutilmoqda
  COMPLETED      // To'liq to'langan
  CANCELLED      // Bekor qilingan
  SUSPENDED      // To'xtatilgan
}

// ─────────────────────────────────────────────────────────────────
// CONTRACT STAGE — to'lov bosqichi (avans, poydevor, devor, yakuniy ...)
// ─────────────────────────────────────────────────────────────────
model ContractStage {
  id            String        @id @default(cuid())
  contractId    String        @map("contract_id")
  contract      Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)

  ordinal       Int                                       // 1, 2, 3, 4 — tartib raqami
  title         String        @db.VarChar(128)            // "Avans", "Poydevor"
  amount        Decimal       @db.Decimal(18, 2)
  percentage    Decimal?      @db.Decimal(5, 2)           // 30.00 — ixtiyoriy
  dueDate       DateTime?     @map("due_date")            // kutilgan to'lov sanasi

  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(18, 2)
  status        StageStatus   @default(PENDING)
  paidAt        DateTime?     @map("paid_at")             // to'liq to'langan sana
  notes         String?       @db.Text

  payments      Payment[]

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([contractId, ordinal])
  @@index([status])
  @@index([dueDate])
  @@map("contract_stages")
}

enum StageStatus {
  PENDING        // To'lanmagan
  PARTIAL        // Qisman to'langan
  PAID           // To'liq to'langan
  OVERDUE        // Muddati o'tgan
}

// ─────────────────────────────────────────────────────────────────
// PAYMENT — bank tranzaksiyasini bosqichga bog'lash (allocation)
// Bitta tranzaksiya bir nechta bosqichga bo'linishi mumkin
// Bitta bosqich bir nechta tranzaksiyadan to'lanishi mumkin
// ─────────────────────────────────────────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  transactionId String        @map("transaction_id")
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  contractId    String        @map("contract_id")
  contract      Contract      @relation(fields: [contractId], references: [id])
  stageId       String        @map("stage_id")
  stage         ContractStage @relation(fields: [stageId], references: [id])

  amount        Decimal       @db.Decimal(18, 2)          // shu bosqichga taqsimlangan summa
  source        PaymentSource @default(AUTO)
  notes         String?       @db.Text

  createdAt     DateTime      @default(now()) @map("created_at")
  createdBy     String?       @map("created_by")          // AdminUser.id (manual link uchun)

  @@index([transactionId])
  @@index([contractId])
  @@index([stageId])
  @@map("payments")
}

enum PaymentSource {
  AUTO           // Avtomatik (INN orqali)
  MANUAL         // Admin qo'lda biriktirgan
}

// ─────────────────────────────────────────────────────────────────
// COUNTERPARTY — kontragentlar registri (DIDOX'dan boyitiladi)
// INN — unique. Foydalanuvchi INN + Name kiritadi, qolgan barcha
// maydonlar DIDOX /v1/ihamkor/companies/{inn} endpoint'idan keladi.
// Name foydalanuvchi kiritgandek qoladi — refresh paytida tegilmaydi.
// ─────────────────────────────────────────────────────────────────
model Counterparty {
  id                String    @id @default(cuid())
  inn               String    @unique @db.VarChar(20)        // 9/14 raqam standart, lekin legacy kodlar uchun (null0004, kod0088, va h.k.) ruxsat etilgan
  name              String    @db.VarChar(255)               // foydalanuvchi kiritgan — refresh'da o'zgarmaydi

  // Qo'lda kiritilgan kontragentlar (INN 9/14 raqamli emas) — DIDOX/Chamber tegmaydi
  isManual          Boolean   @default(false) @map("is_manual")

  // — DIDOX briefData'dan keladigan maydonlar (cron yangilaydi) —
  fullName          String?   @map("full_name") @db.VarChar(255)
  director          String?   @db.VarChar(255)
  directorPinfl     String?   @map("director_pinfl") @db.VarChar(20)
  accountant        String?   @db.VarChar(255)               // glav. bukh — invoice'dan

  phone             String?   @db.VarChar(50)
  email             String?   @db.VarChar(190)
  address           String?   @db.Text                       // billingAddress

  vatNumber         String?   @map("vat_number") @db.VarChar(20)         // Рег. код НДС
  vatStatus         String?   @map("vat_status") @db.VarChar(100)        // "Faol/Nofaol" matn
  vatStatusCode     Int?      @map("vat_status_code")                    // 10/20/21/22/30/50/60
  taxMode           String?   @map("tax_mode") @db.VarChar(50)

  opf               String?   @db.VarChar(100)
  oked              String?   @db.VarChar(255)
  companyType       String?   @map("company_type") @db.VarChar(100)
  businessType      String?   @map("business_type") @db.VarChar(100)
  registrationDate  DateTime? @map("registration_date") @db.Date
  registrationNumber String?  @map("registration_number") @db.VarChar(50)

  // — Reyting (DIDOX sustainabilityRating, Chamber criteriaAll bilan bir xil) —
  rating            Int?
  ratingType        String?   @map("rating_type") @db.VarChar(20)
  ratingTitle       String?   @map("rating_title") @db.VarChar(100)

  // — JSON maydonlar —
  bankAccounts      Json?     @map("bank_accounts")          // [{account, mfo, bankName, lastSeen}, ...]
  founders          Json?                                     // [{fullName, share, ...}, ...]
  rawDidoxBrief     Json?     @map("raw_didox_brief")        // butun briefData (debug uchun)

  // — Tizim metadata —
  addedBy           String    @map("added_by") @db.VarChar(50)   // AdminUser.id
  addedAt           DateTime  @default(now()) @map("added_at")
  lastFetchedAt     DateTime? @map("last_fetched_at")            // oxirgi DIDOX so'rovi
  lastFetchError    String?   @map("last_fetch_error") @db.Text  // agar DIDOX javob bermasa
  isActive          Boolean   @default(true) @map("is_active")
  notes             String?   @db.Text

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Back-relation: qaysi tranzaksiyalar shu kontragent'ga qo'lda bog'langan
  manualTransactions Transaction[] @relation("ManualCounterparty")

  @@index([name])
  @@index([rating])
  @@index([addedBy])
  @@index([lastFetchedAt])
  @@map("counterparties")
}

// ─────────────────────────────────────────────────────────────────
// COUNTERPARTY_HISTORY — audit log
// Har bir o'zgarish (qo'shildi, tahrirlandi, yangilandi, o'chirildi)
// shu yerda saqlanadi: kim, qachon, qaysi manbadan.
// ─────────────────────────────────────────────────────────────────
model CounterpartyHistory {
  id              String   @id @default(cuid())
  inn             String   @db.VarChar(20)               // kontragent INN — easy filter
  action          String   @db.VarChar(20)               // created | manual_edit | refreshed | cron_refresh | imported | deleted
  actorType       String   @map("actor_type") @db.VarChar(10)  // user | cron | system
  actorId         String?  @map("actor_id") @db.VarChar(50)    // AdminUser.id (cron uchun null)
  actorName       String?  @map("actor_name") @db.VarChar(190) // log uchun shu paytdagi nom (admin keyin o'chirilsa ham qoladi)
  source          String?  @db.VarChar(30)               // didox | chamber | didox+chamber | manual | none
  fieldsChanged   String[] @map("fields_changed") @default([])   // qaysi maydonlar o'zgardi
  changes         Json?                                  // {fieldName: {old: '…', new: '…'}, ...} — manual_edit uchun
  note            String?  @db.Text                      // qisqacha izoh

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([inn, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
  @@map("counterparty_history")
}

// ═══════════════════════════════════════════════════════════════
// ОплатыКв — Kvartira to'lovlari (alohida muhim jadval)
// ═══════════════════════════════════════════════════════════════
model OplataKv {
  id                String   @id @default(cuid())

  contractNo        String   @map("contract_no") @db.VarChar(50)        // Дог №
  date              DateTime @db.Date                                    // Дата
  paymentAmount     Decimal? @map("payment_amount") @db.Decimal(15, 2)   // Сумма оплаты (+/-)
  firstInstallment  Decimal? @map("first_installment") @db.Decimal(15, 2) // 1 взнос (+/-)
  monthlyAmount     Decimal? @map("monthly_amount") @db.Decimal(15, 2)   // ежемесячный (+/-)
  purpose           String?  @db.Text                                    // Назначение платежа
  txType            String?  @map("tx_type") @db.VarChar(60)             // Тип
  note              String?  @db.Text                                    // Примечание
  paymentCategory   OplataKvCategory? @map("payment_category")           // Оплата
  object            String?  @db.VarChar(255)                            // Объект
  client            String?  @db.VarChar(255)                            // Клиент
  paymentMethod     String?  @map("payment_method") @db.VarChar(120)     // Способ оплаты

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdById       String?  @map("created_by_id") @db.VarChar(50)       // AdminUser.id
  createdByName     String?  @map("created_by_name") @db.VarChar(190)    // muzlatib qo'yilgan ism
  importBatchId     String?  @map("import_batch_id") @db.VarChar(50)     // ImportBatch.id (agar import bilan kelgan bo'lsa)
  sourceTxId        String?  @unique @map("source_tx_id") @db.VarChar(255) // Transaction externalId (bank kompozit) yoki cuid (dedup uchun unique)

  // Переброска (shartnomadan shartnomaga pul o'tkazma) — guruh ID
  // Source qator (manfiy summa) + N ta destination qator (musbat summa) bir guruhga bog'lanadi.
  // perereboskaFilePath — biriktirilgan hujjat (majburiy) — faqat source qatorda saqlanadi.
  perereboskaGroupId   String?  @map("perereboska_group_id") @db.VarChar(50)
  perereboskaFilePath  String?  @map("perereboska_file_path") @db.Text
  perereboskaFileName  String?  @map("perereboska_file_name") @db.VarChar(255)
  perereboskaFileMime  String?  @map("perereboska_file_mime") @db.VarChar(128)
  perereboskaFileSize  Int?     @map("perereboska_file_size")

  // Tranzaksiyada qo'lda shartnoma tuzatilganda (ariza yoki manual) — true.
  // Manba (МАНБА) ustunida "Qo'lda" badge ko'rsatish uchun.
  wasManuallyEdited    Boolean  @default(false) @map("was_manually_edited")

  // History — FK relation atayin yo'q (CounterpartyHistory pattern): qator o'chirilgandan
  // keyin ham audit log saqlanib qoladi.

  @@index([contractNo])
  @@index([date(sort: Desc)])
  @@index([client])
  @@index([object])
  @@index([paymentCategory])
  @@index([importBatchId])
  @@index([perereboskaGroupId])
  @@map("oplata_kv")
}

// ─────────────────────────────────────────────────────────────────
// OPLATA KV — OBJECT NAME MAPPING (CRM → OplatyKv)
// CRM dan "XON SAROY AFSONASI" kelsa, OplatyKv'ga "АФСОНА" deb yoziladi
// ─────────────────────────────────────────────────────────────────
model OplataKvObjectMapping {
  id            String   @id @default(cuid())
  crmName       String   @unique @map("crm_name") @db.VarChar(255)   // CRM dan keladigan obyekt nomi
  oplataName    String   @map("oplata_name") @db.VarChar(255)        // OplatyKv'ga yoziladigan nom
  createdAt     DateTime @default(now()) @map("created_at")
  createdByName String?  @map("created_by_name") @db.VarChar(190)

  @@index([crmName])
  @@map("oplata_kv_object_mappings")
}

enum OplataKvCategory {
  MONTHLY   // ежемесячный
  FIRST     // 1 взнос
  GENERAL   // Общий
}

model OplataKvHistory {
  id              String   @id @default(cuid())
  oplataKvId      String   @map("oplata_kv_id") @db.VarChar(255)       // OplataKv.id (externalId — bank kompozit 75+) — FK emas

  action          String   @db.VarChar(20)                            // created | edited | deleted | imported
  actorType       String   @map("actor_type") @db.VarChar(10)         // user | system
  actorId         String?  @map("actor_id") @db.VarChar(50)
  actorName       String?  @map("actor_name") @db.VarChar(190)        // full name — muzlatilgan
  fieldsChanged   String[] @map("fields_changed") @default([])
  changes         Json?                                                // {field: {old, new}}
  note            String?  @db.Text

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([oplataKvId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
  @@map("oplata_kv_history")
}
